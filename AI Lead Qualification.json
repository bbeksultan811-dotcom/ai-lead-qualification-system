        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are an AI Sales Qualification Assistant.\\n\\nAnalyze the lead below.\\n\\nName: {{$json.name}}\\nCompany: {{$json.company}}\\nWebsite: {{$json.website}}\\nIndustry: {{$json.industry}}\\nEmployees: {{$json.employees}}\\nCountry: {{$json.country}}\\nBudget: {{$json.budget}}\\nEmail: {{$json.email}}\\nMessage: {{$json.message}}\\n\\nReturn ONLY valid JSON:\\n{\\n\\\"lead_score\\\": 0,\\n\\\"lead_type\\\": \\\"Hot | Warm | Cold\\\",\\n\\\"budget_level\\\": \\\"High | Medium | Low\\\",\\n\\\"summary\\\": \\\"Short summary\\\",\\n\\\"recommended_action\\\": \\\"Next best action\\\"\\n}\\n\\nRules:\\n- Return ONLY JSON.\\n- No markdown.\\n- No explanations.\\n- lead_score must be between 0 and 100.\\n- lead_type must be ONLY Hot, Warm or Cold.\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        416,
        0
