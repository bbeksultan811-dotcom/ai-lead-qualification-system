      "id": "82cfd263-5e81-40f8-abe6-f78992316342",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const lead = $input.first().json;\nconst aiText = lead.candidates[0].content.parts[0].text;\nconst ai = JSON.parse(aiText);\n\nconst form = $('Edit Fields').first().json;\n\nreturn [{\n  json: {\n    ...form,\n\n    lead_score: ai.lead_score,\n    lead_type: ai.lead_type,\n    budget_level: ai.budget_level,\n    summary: ai.summary,\n    recommended_action: ai.recommended_action\n  }\n}];"
      },
